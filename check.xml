    <site name="k73_b18" type="sphere" pos="-2.4 0.67 0.06" size="0.035" rgba="0.68 0.46 0.85 1"/>
    <site name="k2.6e3_b105" type="sphere" pos="0 0.67 0.06" size="0.035" rgba="0.68 0.70 0.72 1"/>
    <site name="k6.6e4_b526" type="sphere" pos="2.4 0.67 0.06" size="0.035" rgba="0.18 0.72 0.95 1"/>
