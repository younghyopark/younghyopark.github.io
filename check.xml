    <geom name="pad_soft_imp_very_fast_ref" class="very_fast_ref_soft_imp" type="box" pos="4.8 -2.0 -0.20" size="0.65 0.65 0.20" material="cube_very_fast_ref_mat"/>
    <body name="soft_imp_very_fast_ref_bottom" pos="4.800 -2.000 1.000">
      <freejoint/>
