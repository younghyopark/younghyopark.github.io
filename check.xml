    <site name="k70_b17" type="sphere" pos="-2.4 2.67 0.06" size="0.035" rgba="0.68 0.46 0.85 1"/>
    <site name="k2.5e3_b100" type="sphere" pos="0 2.67 0.06" size="0.035" rgba="0.68 0.70 0.72 1"/>
    <site name="k6.3e4_b501" type="sphere" pos="2.4 2.67 0.06" size="0.035" rgba="0.18 0.72 0.95 1"/>
    <site name="k1.0e6_b501" type="sphere" pos="4.8 2.67 0.06" size="0.035" rgba="0.95 0.42 0.22 1"/>

    <site name="k69_b17" type="sphere" pos="-2.4 4.67 0.06" size="0.035" rgba="0.68 0.46 0.85 1"/>
    <site name="k2.50e3_b100" type="sphere" pos="0 4.67 0.06" size="0.035" rgba="0.68 0.70 0.72 1"/>
    <site name="k6.3e4_b500" type="sphere" pos="2.4 4.67 0.06" size="0.035" rgba="0.18 0.72 0.95 1"/>
    <site name="k1.0e6_b500" type="sphere" pos="4.8 4.67 0.06" size="0.035" rgba="0.95 0.42 0.22 1"/>

