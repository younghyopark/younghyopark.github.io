    <!-- Pads are thick, with their top surfaces at z=0, so very soft contacts can visibly sink without tunneling through. -->
    <geom name="pad_soft_imp_slow_ref" class="slow_ref_soft_imp" type="box" pos="-2.4 -2.0 -0.20" size="0.65 0.65 0.20" material="cube_slow_ref_mat"/>
