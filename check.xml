<mujoco model="solref_solimp_grid_demo">
  <compiler angle="degree" coordinate="local"/>

  <option
    timestep="0.001"
    gravity="0 0 -9.81"
    integrator="implicitfast"
    solver="Newton"
    iterations="80"
    tolerance="1e-10">
    <flag contact="enable"/>
  </option>

  <!--
    4x4 parameter grid:

      x-axis / columns: solref[0], the contact time constant.
        col 1 = slow restoration:    solref="0.12 1"
        col 2 = default-ish:         solref="0.02 1"
        col 3 = fast restoration:    solref="0.004 1"
        col 4 = fast + underdamped: solref="0.004 0.25"

      y-axis / rows: solimp, the impedance curve.
        row 1 = soft onset:          solimp="0.001 0.55 0.15 0.5 2"
        row 2 = default-ish:         solimp="0.9 0.95 0.001 0.5 2"
        row 3 = rigid onset:         solimp="0.995 0.999 0.0002 0.5 2"
        row 4 = very rigid onset:    solimp="0.9999 0.99999 0.00005 0.5 2"

    All cubes have identical size, mass, friction, starting height, and
    initial offsets. The cubes start with a 10 cm vertical air gap between
    neighbors. Only solref/solimp change across the grid.
  -->
  <default>
    <geom friction="1.2 0.005 0.0001"/>

    <default class="slow_ref_soft_imp">
      <geom solref="0.12 1" solimp="0.001 0.55 0.15 0.5 2"/>
    </default>
    <default class="default_ref_soft_imp">
      <geom solref="0.02 1" solimp="0.001 0.55 0.15 0.5 2"/>
    </default>
    <default class="fast_ref_soft_imp">
      <geom solref="0.004 1" solimp="0.001 0.55 0.15 0.5 2"/>
    </default>
    <default class="very_fast_ref_soft_imp">
      <geom solref="0.004 0.25" solimp="0.001 0.55 0.15 0.5 2"/>
    </default>

    <default class="slow_ref_default_imp">
      <geom solref="0.12 1" solimp="0.9 0.95 0.001 0.5 2"/>
    </default>
    <default class="default_ref_default_imp">
      <geom solref="0.02 1" solimp="0.9 0.95 0.001 0.5 2"/>
    </default>
    <default class="fast_ref_default_imp">
      <geom solref="0.004 1" solimp="0.9 0.95 0.001 0.5 2"/>
    </default>
    <default class="very_fast_ref_default_imp">
      <geom solref="0.004 0.25" solimp="0.9 0.95 0.001 0.5 2"/>
    </default>

    <default class="slow_ref_rigid_imp">
      <geom solref="0.12 1" solimp="0.995 0.999 0.0002 0.5 2"/>
    </default>
    <default class="default_ref_rigid_imp">
      <geom solref="0.02 1" solimp="0.995 0.999 0.0002 0.5 2"/>
    </default>
    <default class="fast_ref_rigid_imp">
      <geom solref="0.004 1" solimp="0.995 0.999 0.0002 0.5 2"/>
    </default>
    <default class="very_fast_ref_rigid_imp">
      <geom solref="0.004 0.25" solimp="0.995 0.999 0.0002 0.5 2"/>
    </default>

    <default class="slow_ref_very_rigid_imp">
      <geom solref="0.12 1" solimp="0.9999 0.99999 0.00005 0.5 2"/>
    </default>
    <default class="default_ref_very_rigid_imp">
      <geom solref="0.02 1" solimp="0.9999 0.99999 0.00005 0.5 2"/>
    </default>
    <default class="fast_ref_very_rigid_imp">
      <geom solref="0.004 1" solimp="0.9999 0.99999 0.00005 0.5 2"/>
    </default>
    <default class="very_fast_ref_very_rigid_imp">
      <geom solref="0.004 0.25" solimp="0.9999 0.99999 0.00005 0.5 2"/>
    </default>
  </default>

  <visual>
    <global azimuth="135" elevation="-25"/>
    <quality shadowsize="2048"/>
  </visual>

  <asset>
    <texture
      name="grid_texture"
      type="2d"
      builtin="checker"
      rgb1="0.16 0.16 0.16"
      rgb2="0.82 0.82 0.82"
      width="512"
      height="512"/>

    <material
      name="grid_material"
      texture="grid_texture"
      texrepeat="14 14"
      reflectance="0.12"/>

    <!-- Cube and pad color encode solref column. -->
    <material name="cube_slow_ref_mat" rgba="0.68 0.46 0.85 1"/>
    <material name="cube_default_ref_mat" rgba="0.68 0.70 0.72 1"/>
    <material name="cube_fast_ref_mat" rgba="0.18 0.72 0.95 1"/>
    <material name="cube_very_fast_ref_mat" rgba="0.95 0.42 0.22 1"/>
  </asset>

  <worldbody>
    <light name="key_light" pos="0 -6 7" dir="0 1 -1" diffuse="0.9 0.9 0.9"/>
    <light name="fill_light" pos="-5 3 4" dir="1 -1 -1" diffuse="0.35 0.35 0.35"/>

    <camera name="grid_view" pos="0.6 -10.2 5.6" xyaxes="1 0 0 0 0.50 0.866"/>
    <camera name="low_side" pos="0.6 -10.8 1.9" xyaxes="1 0 0 0 0.18 0.984"/>

    <!-- Visual-only grid plane. Contact happens on the sixteen colored pads. -->
    <!-- <geom
      name="visual_grid"
      type="plane"
      pos="0 0 -0.04"
      size="6.2 5.3 0.1"
      material="grid_material"
      contype="0"
      conaffinity="0"/> -->

    <!--
      MuJoCo XML has no arbitrary text geom. These named sites act as labels
      when the viewer's site labels are enabled.
    -->
    <site name="solref_0.12" type="box" pos="-2.4 -3.05 0.04" size="0.42 0.035 0.035" rgba="0.68 0.46 0.85 1"/>
    <site name="solref_0.02" type="box" pos="0 -3.05 0.04" size="0.42 0.035 0.035" rgba="0.68 0.70 0.72 1"/>
    <site name="solref_0.004" type="box" pos="2.4 -3.05 0.04" size="0.42 0.035 0.035" rgba="0.18 0.72 0.95 1"/>
    <site name="solref_0.004_0.25" type="box" pos="4.8 -3.05 0.04" size="0.42 0.035 0.035" rgba="0.95 0.42 0.22 1"/>

    <site name="solimp_0.001_0.55_0.15" type="box" pos="-3.55 -2.0 0.04" size="0.035 0.42 0.035" rgba="0.58 0.38 0.78 1"/>
    <site name="solimp_0.9_0.95_0.001" type="box" pos="-3.55 0 0.04" size="0.035 0.42 0.035" rgba="0.46 0.50 0.55 1"/>
    <site name="solimp_0.995_0.999_0.0002" type="box" pos="-3.55 2.0 0.04" size="0.035 0.42 0.035" rgba="0.17 0.58 0.86 1"/>
    <site name="solimp_0.9999_0.99999_0.00005" type="box" pos="-3.55 4.0 0.04" size="0.035 0.42 0.035" rgba="0.95 0.42 0.22 1"/>

    <!--
      Cell labels show the converted stiffness/damping-like values at
      d(r)=d_width:
        k = 1 / (d_width * timeconst^2 * dampratio^2)
        b = 2 / (d_width * timeconst)
    -->
    <site name="k126_b30" type="sphere" pos="-2.4 -1.33 0.06" size="0.035" rgba="0.68 0.46 0.85 1"/>
    <site name="k4.5e3_b182" type="sphere" pos="0 -1.33 0.06" size="0.035" rgba="0.68 0.70 0.72 1"/>
    <site name="k1.1e5_b909" type="sphere" pos="2.4 -1.33 0.06" size="0.035" rgba="0.18 0.72 0.95 1"/>
