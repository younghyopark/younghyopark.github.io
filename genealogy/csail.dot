// CSAIL academic genealogy

// Based on data from The Mathematics Genealogy Project
// (North Dakota State University and the American Mathematical Society)
// Additional data from Wikipedia, Web and library research,
// and the subjects themselves.
// Even more additional data from Neurotree/Academictree.

// Current CSAIL PIs (as of 2026-06) are in CSAIL orange.
// Former CSAIL/LCS/AI/MAC PIs are in CSAIL grey.

strict digraph csail {
	// The main connected component of this graph has a very high
	// fanout.  Setting the aspect ratio should make it better,
	// but it takes an enormous amount of memory and CPU.  After
	// 20 minutes of CPU time, dot(1) had accumulated a *working
	// set* of 4 gigabytes.  It might be worth letting this run
	// overnight just to see if it can get it done in 8 hours and
	// 16 GB of RAM.
	graph [ charset="iso-8859-1", size="120,44", page="121,45", margin=0.25 ];

	// The current version of GraphViz doesn't properly set up
	// the PostScript pagedevice to indicate the size of the page.
	// The comment below should be moved from the comments into
	// the prologue and uncommented for proper display and printing.
	// The sed(1) script "fixup.sed" takes care of this by editing
	// the PostScript output.

    // this is gross
    // we want the label to be at top left, but graphviz stupidly clears
    // the entire top part of the layout just for the label (even though
    // graphviz knows very well how wide the label is, or thinks it does
    // anyway).  so we bury the label in a node (which neato will float
    // somewhere).  ick, why can't graphviz just do this right?
    subgraph just_the_label_thanks {
	// The current version of GraphViz doesn't correctly handle
	// large font sizes in HTML-oid labels.  The PostScript code
	// emitted for the 72-point text line in the label needs to
	// be manually edited to specify a width of 850 points rather
	// than the 292 points that GraphViz comes up with.
	foo [ label=<
<table valign="top" align="left" border="0">
<tr><td align="center"><img src="csail-logo.eps" scale="true"/></td>
<td balign="left" align="left">
<font point-size="72">CSAIL Academic Genealogy</font><br/>
<font point-size="24">Based on data from the Mathematics Genealogy Project (NDSU, AMS) and other sources<br/>
Full CSAIL PIs (as of 2026-06) are outlined in <font color="#cc6600">CSAIL orange</font><br/>
Associate, emeritus, and former CSAIL, AI, and LCS PIs are outlined in <font color="#514b47">CSAIL grey</font><br/>
</font>
<font point-size="16">(Not all former PIs are shown, and some non-PIs may be misidentified.  Teaching relationships become less formal towards the apex.)</font></td>
</tr></table>
>, labelloc="t", labeljust="l"
	 ];
    }
	qrcode [ image="url-qrcode.png", shape=none ]

	// CSAIL principal investigators
	node [ href="http://genealogy.math.ndsu.nodak.edu/id.php?id=\N", shape=box, color="#cc6600", penwidth=5 ];

